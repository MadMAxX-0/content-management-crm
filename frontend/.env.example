# Local: http://localhost:8000
# Prod:  set this in the Vercel dashboard → Project → Settings → Environment Variables
#        to your Railway backend URL, e.g. https://your-app.up.railway.app
NEXT_PUBLIC_API_URL=http://localhost:8000

# Supabase Auth (leave empty to keep the app open; set both to turn login ON).
# From Supabase → Project Settings → API.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
