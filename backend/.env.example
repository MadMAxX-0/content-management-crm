# Copy to .env locally, or set these as environment variables on Railway (Variables tab).
# Do NOT commit real values — .env is gitignored.

# ── Google OAuth (Google Cloud Console → Credentials) ──
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
# Local:  http://localhost:8000/auth/google/callback
# Prod:   https://YOUR-RAILWAY-DOMAIN/auth/google/callback
# (Must be added under "Authorized redirect URIs" in Google Cloud Console.)
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback

# ── CRM settings ──
# Root folder name created on connect → "<COMPANY_NAME>_crm"
COMPANY_NAME=youtopia

# Google Shared Drive ID hosting the CRM folder (empty = My Drive).
SHARED_DRIVE_ID=

# Where to send the user after OAuth connect.
# Local:  http://localhost:3000/drive
# Prod:   https://YOUR-VERCEL-DOMAIN/drive
FRONTEND_URL=http://localhost:3000/drive

# ── Supabase Postgres (Session pooler connection string) ──
DATABASE_URL=

# ── Auth (leave SUPABASE_URL/ANON empty to keep the app open; set them to turn auth ON) ──
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_ANON_KEY=
# Comma-separated emails that get full admin access:
ADMIN_EMAILS=hthbackend@gmail.com
